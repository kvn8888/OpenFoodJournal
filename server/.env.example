# OpenFoodJournal Gemini Proxy — Environment Variables
# Copy this to .env for local development:  cp .env.example .env
# On Render, set these in the Environment tab of your service.

# Required: Your Google AI Studio API key for Gemini
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: Port (Render sets this automatically, defaults to 3000 locally)
# PORT=3000
